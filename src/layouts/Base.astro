---
interface Props {
  pageTitle: string;
  txtColor?: string;
  bgColor?: string;
  txtColorDark?: string;
  bgColorDark?: string;
  // Article-specific meta props
  articleAuthor?: string;
  articlePublishedTime?: string;
  articleDescription?: string;
}

const {
  pageTitle,
  txtColor,
  bgColor,
  txtColorDark,
  bgColorDark,
  articleAuthor,
  articlePublishedTime,
  articleDescription,
} = Astro.props;
---

<html lang="en">
  <head>
    <!-- Core Meta -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="title" content="Édouard Urcades" />
    <meta name="description" content="Designer, Professional" />
    <title>{pageTitle}</title>

    <!-- Basic Favicon and PWA/bookmark Info -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" type="image/png" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/appicon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#000000" />
    <link
      rel="alternate"
      type="application/feed+json"
      href="/feed.json"
      title="JSON Feed"
    />
    <link
      rel="preload"
      as="font"
      type="font/ttf"
      href="/diatype.ttf"
      crossorigin="anonymous"
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://urcad.es/" />
    <meta property="og:title" content="Édouard Urcades" />
    <meta property="og:description" content="Designer, Professional" />
    <meta property="og:image" content="https://www.urcad.es/og.png" />

    <!-- Twitter cards -->
    <meta name="twitter:site" content="@neogeomancer" />
    <meta property="twitter:domain" content="urcad.es" />
    <meta property="twitter:url" content="https://www.urcad.es" />
    <meta name="twitter:title" content="Édouard Urcades" />
    <meta name="twitter:description" content="Designer, Professional" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://www.urcad.es/og.png" />

    <!-- Article-specific meta tags (when applicable) -->
    {articleAuthor && <meta name="author" content={articleAuthor} />}
    {articleAuthor && <meta property="article:author" content={articleAuthor} />}
    {articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {articleDescription && <meta name="description" content={articleDescription} />}

    <!-- Special case blog post styling -->
    <style
      is:global
      define:vars={{ txtColor, bgColor, txtColorDark, bgColorDark }}
    >
      :root {
        color-scheme: light dark;
        --fallback-bg-color: #ffffff;
        --fallback-txt-color: #1a1818;
        --fallback-bg-color-dark: #1a1818;
        --fallback-txt-color-dark: #ffffff;
        --breakpoint-sm: 555px;
        --breakpoint-md: 768px;
        --breakpoint-lg: 1000px;
        --breakpoint-xl: 2222px;
        --space-quarter: 0.25em;
        --space-half: 0.5em;
        --space-1: 1em;
        --space-1-5: 1.5em;
        --space-2: 2em;
        --heading-space: 0.67em;
        --page-gutter-mobile: 1.11em;
        --page-gutter-block: 2em;
        --page-gutter-inline: 2.55em;
        --prose-width: 55ch;
        --title-measure: 22ch;
        --pre-radius: 0.33em;
        --pre-bg-light: #ededed;
        --pre-bg-dark: #333333;
        --text-muted-opacity: 0.6;
        --text-soft-opacity: 0.7;
        --text-note-opacity: 0.75;
        --sketch-grid-gap: var(--space-1);
        --surface-code: var(--pre-bg-light);
      }

      @supports (margin-block: 1lh) {
        :root {
          --space-quarter: 0.25lh;
          --space-half: 0.5lh;
          --space-1: 1lh;
          --space-1-5: 1.5lh;
          --space-2: 2lh;
          --heading-space: 0.67lh;
        }
      }

      @supports (margin: 1rlh) {
        :root {
          --page-gutter-mobile: 0.95rlh;
          --page-gutter-block: 1.65rlh;
          --page-gutter-inline: 2.1rlh;
        }
      }

      /* Use light-dark() for modern color scheme handling */
      @supports (color: light-dark(white, black)) {
        * {
          color: light-dark(
            var(--txtColor, var(--fallback-txt-color)),
            var(--txtColorDark, var(--fallback-txt-color-dark))
          );
        }

        :root {
          --surface-code: light-dark(var(--pre-bg-light), var(--pre-bg-dark));
        }

        body {
          background-color: light-dark(
            var(--bgColor, var(--fallback-bg-color)),
            var(--bgColorDark, var(--fallback-bg-color-dark))
          );
          color: light-dark(
            var(--txtColor, var(--fallback-txt-color)),
            var(--txtColorDark, var(--fallback-txt-color-dark))
          );
        }
      }

      /* Fallback for browsers without light-dark() support */
      @supports not (color: light-dark(white, black)) {
        * {
          color: var(--txtColor, var(--fallback-txt-color));

          @media (prefers-color-scheme: dark) {
            color: var(--txtColorDark, var(--fallback-txt-color-dark));
          }
        }

        :root {
          --surface-code: var(--pre-bg-light);

          @media (prefers-color-scheme: dark) {
            --surface-code: var(--pre-bg-dark);
          }
        }

        body {
          background-color: var(--bgColor, var(--fallback-bg-color));
          color: var(--txtColor, var(--fallback-txt-color));

          @media (prefers-color-scheme: dark) {
            background-color: var(--bgColorDark, var(--fallback-bg-color-dark));
            color: var(--txtColorDark, var(--fallback-txt-color-dark));
          }
        }
      }

      html {
        margin: var(--page-gutter-mobile);

        @media screen and (min-width: 555px) {
          margin: var(--page-gutter-block) var(--page-gutter-inline);
          padding-block-end: var(--page-gutter-block);
        }
      }

      body {
        font-family: "Times New Roman", Times, serif;
        font-size: 1.23em;
        -webkit-font-smoothing: antialiased;
      }

      .prose {
        max-width: var(--prose-width);
        text-wrap: pretty;
      }

      .title-measure {
        max-width: var(--title-measure);
      }

      .prose img {
        display: inline-block;
        max-width: 100%;
        height: auto;
        padding-block-end: var(--space-1);
      }

      .prose video {
        display: block;
        max-width: 100%;
        height: auto;
        margin-block-end: var(--space-1);
      }

      .prose blockquote {
        font-style: italic;
        padding-inline-start: var(--space-1);
        margin-inline-start: 0;
        border-inline-start: 1px solid currentColor;
      }

      .prose pre {
        padding: var(--space-1);
        overflow-x: auto;
        border-radius: var(--pre-radius);
        background-color: var(--surface-code);
      }

      @supports selector(:has(*)) {
        .prose:has(img:last-child) img:last-child {
          padding-block-end: 0;
        }
      }

      @supports not selector(:has(*)) {
        .prose img:last-of-type {
          padding-block-end: 0;
        }
      }

      .text-muted {
        opacity: var(--text-muted-opacity);
      }

      .text-soft {
        opacity: var(--text-soft-opacity);
      }

      .text-note {
        opacity: var(--text-note-opacity);
      }

      .button-reset {
        background: none;
        border: none;
        padding: 0;
        font: inherit;
      }

      .responsive-break {
        display: inline;

        @media screen and (max-width: 554px) {
          display: none;
        }
      }

      .list-circle li {
        list-style: circle;
      }

      .sketch-grid {
        container-type: inline-size;
        display: flex;
        flex-wrap: wrap;
        gap: var(--sketch-grid-gap);

        @media (min-width: 768px) {
          justify-content: flex-start;
        }
      }

      :where(main, article, nav, header, footer)
        > :where(p, ul, ol, dl, blockquote, pre, figure) {
        margin-block: var(--space-1);
      }

      :where(main, article, nav, header, footer)
        > :where(h1, h2, h3, h4, h5, h6) {
        margin-block: var(--heading-space);
      }

      :is(a, button) {
        text-decoration: none;
        cursor: pointer;
      }

      /* Modern text wrapping */
      :is(h1, h2, h3, h4, h5, h6) {
        text-wrap: balance;
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <p><a href="/">É. Urcades</a></p>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
