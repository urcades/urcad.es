---
import Base from "../layouts/Base.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type PostEntry = CollectionEntry<"writing"> | CollectionEntry<"drafts">;

const writingPosts = await getCollection("writing");
const pageTitle = "É. Urcades: Ongoing Writing";

// In development mode, include drafts alongside published posts
let allPosts: PostEntry[] = writingPosts;
if (import.meta.env.DEV) {
  const draftPosts = await getCollection("drafts");
  allPosts = [...writingPosts, ...draftPosts];
}

function groupPostsByYear(posts: PostEntry[]): Record<string, PostEntry[]> {
  const grouped = posts.reduce(
    (acc, post) => {
      const year = post.data.pubDate.getFullYear().toString();
      acc[year] = acc[year] || [];
      acc[year].push(post);
      return acc;
    },
    {} as Record<string, PostEntry[]>
  );

  // Sort each year's posts once after grouping (O(n + klog(k)) instead of O(n²log(n)))
  Object.values(grouped).forEach((yearPosts) => {
    yearPosts.sort(
      (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
    );
  });

  return grouped;
}

function isDraft(post: PostEntry): boolean {
  return post.collection === "drafts";
}

function isStream(post: PostEntry): boolean {
  return post.data.tags?.includes("stream") ?? false;
}

const groupedPosts = groupPostsByYear(allPosts);
const sortedYears = Object.keys(groupedPosts).sort(
  (a, b) => Number(b) - Number(a)
);

const streamPostCount = allPosts.filter(isStream).length;
---

<Base pageTitle={pageTitle}>
  <p>
    Ongoing records, ideas, thoughts,
    {
      streamPostCount > 0 && (
        <>
          <button
            id="stream-toggle"
            class="button-reset"
            type="button"
            aria-label="Hide stream posts"
          >
              streams
          </button>
        </>
      )
    }
  </p>
  {
    sortedYears.map((year) => {
      const yearPosts = groupedPosts[year] ?? [];

      return (
        <div
          class="writing-year"
          data-stream-only-year={yearPosts.every(isStream) ? "true" : undefined}
        >
          <em>{year}</em>
          <ul class="list-circle">
            {yearPosts.map((post) => (
              <li data-stream-post={isStream(post) ? "true" : undefined}>
                <a
                  href={`/${post.collection}/${post.id}/`}
                  title={post.data.pubDate.toISOString()}
                  data-astro-prefetch
                >
                  {isDraft(post) && "[DRAFT] "}
                  {post.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      );
    })
  }
  <br />
  <p><a href="https://urcades.substack.com/">Subscribe</a></p>
  <p><a href="/rss.xml">RSS</a></p>

  <script>
    const streamToggle =
      document.querySelector<HTMLButtonElement>("#stream-toggle");
    const streamPosts = Array.from(
      document.querySelectorAll<HTMLElement>("[data-stream-post='true']")
    );
    const streamOnlyYears = Array.from(
      document.querySelectorAll<HTMLElement>("[data-stream-only-year='true']")
    );
    const storageKey = "urcades:writing:show-streams";

    function readStoredVisibility() {
      try {
        const storedValue = window.localStorage.getItem(storageKey);
        return storedValue === null ? true : storedValue === "true";
      } catch {
        return true;
      }
    }

    function writeStoredVisibility(showStreams: boolean) {
      try {
        window.localStorage.setItem(storageKey, String(showStreams));
      } catch {
        // Storage can be unavailable in private or hardened browser contexts.
      }
    }

    function setStreamVisibility(
      toggle: HTMLButtonElement,
      showStreams: boolean
    ) {
      for (const post of streamPosts) {
        post.hidden = !showStreams;
      }

      for (const year of streamOnlyYears) {
        year.hidden = !showStreams;
      }

      toggle.textContent = showStreams ? "streams (hide)" : "streams (show)";
      toggle.setAttribute(
        "aria-label",
        showStreams ? "Hide stream posts" : "Show stream posts"
      );
    }

    if (streamToggle && streamPosts.length > 0) {
      let showStreams = readStoredVisibility();
      setStreamVisibility(streamToggle, showStreams);

      streamToggle.addEventListener("click", () => {
        showStreams = !showStreams;
        setStreamVisibility(streamToggle, showStreams);
        writeStoredVisibility(showStreams);
      });
    }
  </script>

</Base>
