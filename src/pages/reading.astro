---
import Base from "../layouts/Base.astro";
import readings from "../data/readings.json";

const pageTitle = "Reading";

const books = readings.books
  .filter((book: any) => book.highlights.length > 0)
  .sort((a: any, b: any) => b.highlights.length - a.highlights.length);

const totalHighlights = books.reduce(
  (sum: number, book: any) => sum + book.highlights.length,
  0
);
---

<style>
  .book-section {
    margin-block: var(--space-1);
  }

  .book-header {
    margin-block-end: var(--space-1-5);
  }

  .book-title {
    font-style: italic;
    margin: 0;
  }

  .book-author {
    margin: 0;
    margin-block-start: var(--space-quarter);
  }

  .book-count {
    margin: 0;
  }

  .empty-state {
    font-style: italic;
  }
</style>

<Base pageTitle={pageTitle}>
  <p>{totalHighlights} highlights from {books.length} books</p>

  <div class="prose">
    {books.length === 0 && <p class="empty-state text-muted">No highlights yet.</p>}

    {
      books.map((book: any) => (
        <section class="book-section">
          <div class="book-header">
            <p class="book-title">
              <a href={`/reading/${book.id}/`} data-astro-prefetch>{book.title}</a>
            </p>
            <p class="book-author text-soft">{book.author}</p>
            <p class="book-count text-muted">
              {book.highlights.length}{" "}
              {book.highlights.length === 1 ? "highlight" : "highlights"}
            </p>
          </div>
        </section>
      ))
    }
  </div>

  <script>
    const highlightId = window.location.hash.slice(1);

    if (highlightId) {
      fetch("/reading/highlights.json")
        .then((response) => response.ok ? response.json() : {})
        .then((highlightRoutes: Record<string, string>) => {
          const target = highlightRoutes[highlightId];
          if (target) window.location.replace(target);
        })
        .catch(() => {});
    }
  </script>
</Base>
