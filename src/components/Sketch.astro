---
import { Image } from "astro:assets";

interface Props {
  imageUrl: string;
  title: string;
  category: string;
  url?: string;
  size?: string;
  caseStudyUrl?: string;
  priority?: boolean;
}

const {
  imageUrl,
  title,
  category,
  url,
  size = "1",
  caseStudyUrl,
  priority = false,
} = Astro.props;

const imageProfiles: Record<string, { sizes: string; widths: number[] }> = {
  "1": {
    sizes: "(min-width: 2222px) 25vw, (min-width: 1000px) 33vw, (min-width: 800px) 50vw, 100vw",
    widths: [320, 480, 640, 800, 960, 1280],
  },
  "2": {
    sizes: "(min-width: 2222px) 50vw, (min-width: 1000px) 67vw, 100vw",
    widths: [320, 640, 960, 1280, 1600, 2000, 2400],
  },
  "3": {
    sizes: "(min-width: 2222px) 75vw, 100vw",
    widths: [320, 640, 960, 1280, 1600, 2000, 2400, 3200],
  },
};

const imageProfile = imageProfiles[size] ?? {
  sizes: "100vw",
  widths: [320, 640, 960, 1280, 1600],
};
---

<style>
  .sketch {
    --sketch-width-base: 100%;
    width: var(--sketch-width-base);
    margin-block-end: var(--sketch-grid-gap, var(--space-1));

    /* Use container queries where supported */
    @supports (container-type: inline-size) {
      @container (min-width: 800px) {
        --sketch-width-base: calc(50% - var(--sketch-grid-gap, var(--space-1)));

        &[data-size="2"],
        &[data-size="3"] {
          --sketch-width-base: calc(100% - var(--sketch-grid-gap, var(--space-1)));
        }
      }

      @container (min-width: 1000px) {
        --sketch-width-base: calc(33.333% - var(--sketch-grid-gap, var(--space-1)));

        &[data-size="2"] {
          --sketch-width-base: calc(66.666% - var(--sketch-grid-gap, var(--space-1)));
        }

        &[data-size="3"] {
          --sketch-width-base: calc(100% - var(--sketch-grid-gap, var(--space-1)));
        }
      }

      @container (min-width: 2222px) {
        --sketch-width-base: calc(25% - var(--sketch-grid-gap, var(--space-1)));

        &[data-size="2"] {
          --sketch-width-base: calc(50% - var(--sketch-grid-gap, var(--space-1)));
        }

        &[data-size="3"] {
          --sketch-width-base: calc(75% - var(--sketch-grid-gap, var(--space-1)));
        }
      }
    }

    /* Fallback to media queries for older browsers */
    @supports not (container-type: inline-size) {
      @media (min-width: 800px) {
        --sketch-width-base: calc(50% - var(--sketch-grid-gap, var(--space-1)));

        &[data-size="2"],
        &[data-size="3"] {
          --sketch-width-base: calc(100% - var(--sketch-grid-gap, var(--space-1)));
        }
      }

      @media (min-width: 1000px) {
        --sketch-width-base: calc(33.333% - var(--sketch-grid-gap, var(--space-1)));

        &[data-size="2"] {
          --sketch-width-base: calc(66.666% - var(--sketch-grid-gap, var(--space-1)));
        }

        &[data-size="3"] {
          --sketch-width-base: calc(100% - var(--sketch-grid-gap, var(--space-1)));
        }
      }

      @media (min-width: 2222px) {
        --sketch-width-base: calc(25% - var(--sketch-grid-gap, var(--space-1)));

        &[data-size="2"] {
          --sketch-width-base: calc(50% - var(--sketch-grid-gap, var(--space-1)));
        }

        &[data-size="3"] {
          --sketch-width-base: calc(75% - var(--sketch-grid-gap, var(--space-1)));
        }
      }
    }
  }

  :global(.sketch-image) {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .sketch-info {
    margin-block-start: var(--space-half);
  }
</style>

<div class="sketch" data-size={size}>
  <Image
    class="sketch-image"
    src={imageUrl}
    alt={title}
    inferSize
    priority={priority}
    widths={imageProfile.widths}
    sizes={imageProfile.sizes}
  />
  <div class="sketch-info">
    <p>{title}</p>
    <em>{category}</em>
    {
      caseStudyUrl && (
        <>
          {" "}
          <a href={caseStudyUrl} data-astro-prefetch>⌘</a>
        </>
      )
    }
    {
      url && (
        <>
          {" "}
          <a href={url} target="_blank" rel="noopener">
            ♨︎
          </a>
        </>
      )
    }
  </div>
</div>
